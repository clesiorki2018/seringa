# Copie este arquivo para .env e ajuste os valores locais antes do build.
SERINGA_WIFI_SSID=nome-da-rede
SERINGA_WIFI_PASS=senha-da-rede

# Hash DJB2 do PIN usado no login web, no formato hexadecimal C.
# Gere com:
#   python3 -c 'h=5381
# for c in "1234": h=((h << 5) + h + ord(c)) & 0xffffffff
# print(f"0x{h:08x}")'
SERINGA_PIN_HASH=0x00000000
